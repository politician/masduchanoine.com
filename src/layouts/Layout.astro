---
interface HreflangPair {
  fr: string;
  en?: string;
}

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  lang?: 'fr' | 'en';
  hreflang?: HreflangPair;
  schemaOrg?: object;
}

const {
  title,
  description,
  canonical,
  ogImage = 'https://masduchanoine.com/og-image.jpg',
  lang = 'fr',
  hreflang,
  schemaOrg,
} = Astro.props;

const ogLocale = lang === 'fr' ? 'fr_FR' : 'en_US';
const schemaJson = schemaOrg ? JSON.stringify(schemaOrg) : null;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Hreflang -->
    {hreflang && (
      <>
        <link rel="alternate" hreflang="fr" href={`https://masduchanoine.com${hreflang.fr}`} />
        {hreflang.en && (
          <link rel="alternate" hreflang="en" href={`https://masduchanoine.com${hreflang.en}`} />
        )}
        <link rel="alternate" hreflang="x-default" href={`https://masduchanoine.com${hreflang.fr}`} />
      </>
    )}

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mas du Chanoine" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema.org JSON-LD -->
    {schemaJson && <script type="application/ld+json" set:html={schemaJson} />}

    <style>
      :root {
        --font-heading: 'Playfair Display', Georgia, serif;
        --font-body: 'Lato', system-ui, sans-serif;
      }
      html {
        font-family: var(--font-body);
        background-color: #faf9f7;
        color: #2c2c2c;
        scroll-behavior: smooth;
      }
      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
      }
    </style>
  </head>
  <body class="bg-cream text-charcoal">
    <slot name="header" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
