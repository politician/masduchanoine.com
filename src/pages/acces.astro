---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BedAndBreakfast",
  "name": "Mas du Chanoine",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "831 chemin de la Bastide Rouge",
    "addressLocality": "Saint-Paul de Vence",
    "postalCode": "06570",
    "addressCountry": "FR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 43.6949,
    "longitude": 7.1134
  },
  "hasMap": "https://www.google.com/maps?q=le+mas+du+chanoine+st+paul+de+vence"
};
---

<BaseLayout
  title="Accès — Comment venir au Mas du Chanoine, Saint-Paul de Vence"
  description="Plan d'accès et itinéraire pour rejoindre le Mas du Chanoine à Saint-Paul de Vence. 831 chemin de la Bastide Rouge, entre Nice et Cannes sur la Côte d'Azur."
  structuredData={structuredData}
>
  <section class="relative py-20 md:py-28 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-primary-100"></div>
    <div class="relative z-10 text-center max-w-3xl mx-auto">
      <p class="text-sm tracking-[0.3em] uppercase mb-4 text-accent-600 font-light">Informations pratiques</p>
      <h1 class="text-4xl md:text-5xl font-serif font-semibold text-primary-900">Accès</h1>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Map -->
        <div>
          <div class="aspect-[4/3] rounded-sm overflow-hidden shadow-lg">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2883.5!2d7.1134!3d43.6949!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sLe+Mas+du+Chanoine!5e0!3m2!1sfr!2sfr!4v1234567890"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Localisation du Mas du Chanoine"
            ></iframe>
          </div>
          <div class="mt-4">
            <a
              href="https://www.google.com/maps/search/le+mas+du+chanoine+st+paul+de+vence"
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent-600 hover:text-accent-700 text-sm font-medium underline underline-offset-4"
            >
              Ouvrir dans Google Maps →
            </a>
          </div>
        </div>

        <!-- Info -->
        <div>
          <div class="bg-primary-50 rounded-sm p-8 md:p-10 mb-8">
            <h2 class="text-xl font-serif font-semibold text-primary-900 mb-4">Notre adresse</h2>
            <address class="not-italic text-primary-700 space-y-2 mb-6">
              <p class="font-semibold text-lg">Le Mas du Chanoine</p>
              <p>831 chemin de la Bastide Rouge</p>
              <p>06570 Saint-Paul de Vence</p>
              <p>Côte d'Azur, France</p>
            </address>
            <div class="space-y-3 text-sm">
              <a href="tel:+33627271649" class="flex items-center gap-2 text-primary-700 hover:text-accent-600 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                +33 (0)6 27 27 16 49
              </a>
              <a href="mailto:pascale@masduchanoine.com" class="flex items-center gap-2 text-primary-700 hover:text-accent-600 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                pascale@masduchanoine.com
              </a>
              <a href="https://wa.me/33627271649" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-primary-700 hover:text-accent-600 transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp
              </a>
            </div>
          </div>

          <div class="space-y-6">
            <div>
              <h3 class="font-serif font-semibold text-primary-900 mb-2">En voiture</h3>
              <p class="text-sm text-primary-600 leading-relaxed">
                Depuis l'autoroute A8 (La Provençale), prendre la sortie Cagnes-sur-Mer puis suivre la direction Saint-Paul de Vence. Le Mas du Chanoine se situe sur le chemin de la Bastide Rouge, à quelques minutes du village.
              </p>
            </div>
            <div>
              <h3 class="font-serif font-semibold text-primary-900 mb-2">En avion</h3>
              <p class="text-sm text-primary-600 leading-relaxed">
                L'aéroport le plus proche est l'aéroport Nice Côte d'Azur, situé à environ 20 minutes de route. Possibilité de transfert sur demande.
              </p>
            </div>
            <div>
              <h3 class="font-serif font-semibold text-primary-900 mb-2">En train</h3>
              <p class="text-sm text-primary-600 leading-relaxed">
                Les gares les plus proches sont Nice-Ville et Cagnes-sur-Mer. Depuis la gare, vous pouvez prendre un taxi ou un bus en direction de Saint-Paul de Vence.
              </p>
            </div>
            <div>
              <h3 class="font-serif font-semibold text-primary-900 mb-2">Parking</h3>
              <p class="text-sm text-primary-600 leading-relaxed">
                Parking privé gratuit dans la propriété.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
