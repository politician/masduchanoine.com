---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contactez-nous — Mas du Chanoine"
  description="Contactez le Mas du Chanoine pour une demande de disponibilité ou réservation de chambre d'hôtes à Saint-Paul de Vence."
>
  <!-- Header -->
  <section class="relative py-20 md:py-28 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-primary-100"></div>
    <div class="relative z-10 text-center max-w-3xl mx-auto">
      <p class="text-sm tracking-[0.3em] uppercase mb-4 text-accent-600 font-light">Nous contacter</p>
      <h1 class="text-4xl md:text-5xl font-serif font-semibold text-primary-900">Contactez-nous</h1>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">

        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-primary-900 mb-6">Demandes de disponibilité</h2>
          <p class="text-primary-600 mb-8 leading-relaxed text-base md:text-lg">
            Pour toute demande de disponibilité ou de réservation, n'hésitez pas à nous joindre par téléphone, email ou WhatsApp. Pascale et Yves se feront un plaisir de vous répondre.
          </p>

          <!-- Contact Details -->
          <div class="space-y-6 mb-10">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-accent-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-primary-900 mb-1">Téléphone</h3>
                <a href="tel:+33627271649" class="text-accent-600 hover:text-accent-700 text-lg font-medium">+33 (0)6 27 27 16 49</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-accent-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-primary-900 mb-1">Email</h3>
                <a href="mailto:pascale@masduchanoine.com" class="text-accent-600 hover:text-accent-700 text-lg font-medium">pascale@masduchanoine.com</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-accent-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-600" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-primary-900 mb-1">WhatsApp</h3>
                <a href="https://wa.me/33627271649" target="_blank" rel="noopener noreferrer" class="text-accent-600 hover:text-accent-700 text-lg font-medium">Nous écrire sur WhatsApp</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-accent-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-primary-900 mb-1">Adresse</h3>
                <address class="not-italic text-primary-600">
                  <p>831 chemin de la Bastide Rouge</p>
                  <p>06570 Saint Paul de Vence</p>
                  <p>Côte d'Azur, France</p>
                </address>
              </div>
            </div>
          </div>

          <!-- Social Links -->
          <div class="flex flex-wrap gap-4 mb-10">
            <a href="https://www.instagram.com/masduchanoine/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 border border-primary-200 rounded-sm text-sm text-primary-600 hover:border-accent-500 hover:text-accent-600 transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              Instagram
            </a>
            <a href="https://www.facebook.com/MasDuChanoine/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 border border-primary-200 rounded-sm text-sm text-primary-600 hover:border-accent-500 hover:text-accent-600 transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebook
            </a>
          </div>

          <!-- Booking CTA Card -->
          <div class="bg-accent-600 text-white rounded-sm p-6 md:p-8">
            <h3 class="text-xl font-serif font-semibold mb-3">Réservez directement</h3>
            <p class="text-white/80 text-sm mb-4 leading-relaxed">
              Notez que vous pouvez également effectuer une réservation directement via notre moteur de réservation en ligne. Le meilleur tarif est garanti en réservant directement.
            </p>
            <a
              href="https://masduchanoine.thais-hotel.com/hotel/website/reservations.php?lang=fr"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary bg-white text-primary-900 hover:bg-primary-100"
            >
              Réserver maintenant
            </a>
          </div>

          <!-- Privacy link -->
          <p class="mt-6 text-sm text-primary-500">
            Vos données sont traitées conformément à notre
            <a href="/politique-de-confidentialite/" class="text-accent-600 hover:text-accent-700 underline underline-offset-4">politique de confidentialité</a>.
          </p>
        </div>

        <!-- Map -->
        <div>
          <div class="aspect-[4/3] rounded-sm overflow-hidden shadow-lg mb-6">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2885.6!2d7.0584!3d43.6951!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12cdd1f0c5e1e29f%3A0x5f5b5b5b5b5b5b5b!2sMas%20du%20Chanoine!5e0!3m2!1sfr!2sfr!4v1"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Localisation du Mas du Chanoine à Saint-Paul de Vence"
            ></iframe>
          </div>
          <a
            href="https://www.google.com/maps/search/le+mas+du+chanoine+st+paul+de+vence"
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent-600 hover:text-accent-700 text-sm font-medium underline underline-offset-4"
          >
            Ouvrir dans Google Maps →
          </a>

          <!-- Quick info card -->
          <div class="mt-8 bg-primary-50 rounded-sm p-6 md:p-8">
            <h3 class="font-serif font-semibold text-primary-900 mb-4 text-lg">Informations pratiques</h3>
            <div class="space-y-3 text-sm text-primary-600">
              <div class="flex items-start gap-3">
                <span class="text-accent-600 font-semibold mt-0.5">→</span>
                <p><strong class="text-primary-900">Arrivée :</strong> entre 17h et 19h</p>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-accent-600 font-semibold mt-0.5">→</span>
                <p><strong class="text-primary-900">Départ :</strong> avant 11h</p>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-accent-600 font-semibold mt-0.5">→</span>
                <p><strong class="text-primary-900">Parking :</strong> gratuit dans la propriété</p>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-accent-600 font-semibold mt-0.5">→</span>
                <p><strong class="text-primary-900">Petit déjeuner :</strong> inclus</p>
              </div>
            </div>
            <div class="mt-6">
              <a href="/acces" class="text-sm text-accent-600 hover:text-accent-700 font-medium underline underline-offset-4">
                Comment venir au Mas du Chanoine →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
