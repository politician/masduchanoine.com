---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BedAndBreakfast",
  "name": "Mas du Chanoine",
  "description": "Maison d'hôtes de charme à Saint-Paul de Vence, Côte d'Azur. Mas du 17ème siècle avec piscine, 4 suites luxueuses, entre Nice et Cannes.",
  "url": "https://masduchanoine.com",
  "telephone": "+33627271649",
  "email": "pascale@masduchanoine.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "831 chemin de la Bastide Rouge",
    "addressLocality": "Saint-Paul de Vence",
    "postalCode": "06570",
    "addressRegion": "Côte d'Azur",
    "addressCountry": "FR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 43.7,
    "longitude": 7.11
  },
  "image": "https://masduchanoine.com/media/hero-mas-du-chanoine.jpg",
  "priceRange": "€€€",
  "starRating": {
    "@type": "Rating",
    "ratingValue": "5"
  },
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Piscine", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Wi-Fi gratuit", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Parking gratuit", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Petit-déjeuner inclus", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Climatisation", "value": true }
  ],
  "sameAs": [
    "https://www.facebook.com/MasDuChanoine/",
    "https://www.instagram.com/masduchanoine/",
    "https://twitter.com/masduchanoine"
  ]
};

const rooms = [
  {
    name: 'La Cannoise',
    slug: '/chambres-hotes/la-cannoise/',
    tagline: 'Provençale Chic & Moderne',
    description: 'Chambre d\'hôtes baignée de soleil, avec vue sur le bassin, style provençal chic et branché star de Cannes',
    details: 'Suite junior · 36 m² · 2 pers. · Lit King Size · Douche italienne',
    image: '/media/chambres/chambre-cannoise.jpg',
  },
  {
    name: 'La Niçoise',
    slug: '/chambres-hotes/la-nicoise/',
    tagline: 'Spacieuse & Cosy',
    description: 'Chambre d\'hôtes sous le citronnier, avec vue sur le bassin, style provençal, le charme du Vieux Nice',
    details: 'Suite junior · 36 m² · 2 pers. · Lit King Size ou lits jumeaux · Douche italienne',
    image: '/media/chambres/chambre-nicoise.jpg',
  },
  {
    name: 'La Saint Pauloise',
    slug: '/chambres-hotes/la-saint-pauloise/',
    tagline: 'Charme & Vue sur le village',
    description: 'Dans la partie la plus ancienne du Mas, chambre de maître avec vue sur le village de Saint-Paul de Vence',
    details: '1er étage · 30 m² · 2 pers. · Lit King Size · Baignoire & douche',
    image: '/media/chambres/chambre-saint-pauloise.jpg',
  },
  {
    name: 'Le Petit Mas',
    slug: '/chambres-hotes/petit-mas/',
    tagline: 'Indépendant & Familial',
    description: 'Petit appartement indépendant avec 2 chambres, pour les personnes voyageant à trois, vue sur le bassin',
    details: 'Suite familiale · 35 m² · 3 pers. · 2 chambres · Douche italienne',
    image: '/media/chambres/chambre-petit-mas.jpg',
  },
];

const highlights = [
  { icon: '🏘️', title: 'Saint-Paul de Vence', text: 'Village authentique du Moyen-Âge, mondialement connu, fréquenté par les artistes' },
  { icon: '🏛️', title: 'Mas du 17ème siècle', text: 'Une maison chargée d\'histoire au confort moderne et chaleureux' },
  { icon: '🛏️', title: 'Seulement 4 suites', text: 'Cadre intimiste, calme et reposant' },
  { icon: '🏊', title: 'Piscine avec vue', text: 'Bassin de 12m × 6m dans un espace aménagé' },
  { icon: '🎯', title: 'Service personnalisé', text: 'Conciergerie, organisation de vos journées, réservation de vos restaurants' },
];

const testimonials = [
  {
    text: 'Nous avons passé des vacances fantastiques ici, de la première à la dernière minute. Merci pour toutes les informations que nous avons reçues sur la région et les bons restaurants. Vous étiez les meilleurs guides que nous pouvions imaginer. Tout a été soigné dans les moindres détails et particulièrement le bon petit déjeuner. Heureux de prendre chaque jour un plonge dans la piscine. Nous manquons de superlatifs pour vous remercier, quelle hospitalité !',
    author: 'Christine et Patrick',
    origin: 'Belgique',
  },
  {
    text: 'Nous avons rencontré un petit coin de paradis, tenu par des hôtes de charme. Sincèrement, ce lieu est magnifique, un havre de paix à proximité du superbe village de Saint-Paul de Vence. Félicitations à Pascale et Yves pour avoir réussi à créer une telle ambiance. Merci pour tout.',
    author: 'Claude et Franck',
    origin: 'Sarthe',
  },
  {
    text: 'Une bâtisse de charme dans un jardin magnifique – oranges et citrons à portée de main – mais surtout des hôtes chaleureux, attentionnés, d\'une extrême gentillesse. Difficile de partir tant on se sent bien, mais on reviendra, en été, pour profiter de la piscine et… des confitures de Pascale.',
    author: 'Jean Louis',
    origin: 'France',
  },
];
---

<BaseLayout
  title="Mas du Chanoine — Chambres d'hôtes de charme à Saint-Paul de Vence, Côte d'Azur"
  description="Au cœur de la Côte d'Azur, entre Cannes et Nice, le Mas du Chanoine vous propose des chambres d'hôtes de charme à Saint-Paul de Vence. Mas du 17ème siècle, piscine, prestations haut de gamme."
  structuredData={structuredData}
>
  <!-- Hero Section with Image Slider -->
  <section class="relative h-[85vh] min-h-[600px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-primary-950/60 via-primary-950/40 to-primary-950/70 z-10"></div>
    <!-- Slider images -->
    <div class="absolute inset-0" id="hero-slider">
      <div class="absolute inset-0 bg-cover bg-center transition-opacity duration-1000 opacity-100" style="background-image: url('/media/slider-vue-mas.jpg')"></div>
      <div class="absolute inset-0 bg-cover bg-center transition-opacity duration-1000 opacity-0" style="background-image: url('/media/slider-piscine.jpg')"></div>
      <div class="absolute inset-0 bg-cover bg-center transition-opacity duration-1000 opacity-0" style="background-image: url('/media/slider-bassin.jpg')"></div>
    </div>
    <div class="relative z-20 text-center text-white px-4 max-w-4xl mx-auto">
      <p class="text-sm md:text-base tracking-[0.3em] uppercase mb-4 text-primary-200 font-light">Saint-Paul de Vence · Côte d'Azur</p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-serif font-semibold mb-6 leading-tight">
        Mas du Chanoine
      </h1>
      <p class="text-lg md:text-xl font-light mb-10 max-w-2xl mx-auto text-primary-100 leading-relaxed">
        Maison d'hôtes de charme dans un mas du 17<sup>ème</sup> siècle, entre Cannes et Nice
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://masduchanoine.thais-hotel.com/hotel/website/reservations.php?lang=fr" target="_blank" rel="noopener noreferrer" class="btn-primary bg-white text-primary-900 hover:bg-primary-100">
          Réserver maintenant
        </a>
        <a href="/chambres-dhotes/" class="btn-outline border-white text-white hover:bg-white hover:text-primary-900">
          Découvrir nos chambres
        </a>
      </div>
    </div>
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-bounce">
      <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Highlights Strip -->
  <section class="bg-primary-50 border-y border-primary-100">
    <div class="max-w-7xl mx-auto px-4 md:px-8 py-12">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8 text-center">
        {highlights.map((h) => (
          <div class="space-y-2">
            <span class="text-3xl" aria-hidden="true">{h.icon}</span>
            <h2 class="font-serif font-semibold text-sm md:text-base text-primary-900">{h.title}</h2>
            <p class="text-xs md:text-sm text-primary-600 leading-relaxed">{h.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Image Showcase -->
  <section class="grid md:grid-cols-3 gap-0">
    <div class="aspect-[4/3] md:aspect-auto overflow-hidden">
      <img
        src="/media/piscine-fleurs.jpg"
        alt="La piscine et ses fleurs au Mas du Chanoine"
        class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
        loading="lazy"
        width="600"
        height="400"
      />
    </div>
    <div class="aspect-[4/3] md:aspect-auto overflow-hidden">
      <img
        src="/media/chambres/chambre-nicoise.jpg"
        alt="La chambre Niçoise"
        class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
        loading="lazy"
        width="600"
        height="400"
      />
    </div>
    <div class="aspect-[4/3] md:aspect-auto overflow-hidden">
      <img
        src="/media/chambres/nicoise-salon-jardin.jpg"
        alt="Salon de jardin de la chambre Niçoise"
        class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
        loading="lazy"
        width="600"
        height="400"
      />
    </div>
  </section>

  <!-- Presentation -->
  <section class="section-pad">
    <div class="container-narrow">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-sm tracking-[0.2em] uppercase text-accent-600 mb-3 font-medium">Bienvenue</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-6 text-primary-900 leading-tight">
            Maison d'hôtes de charme à Saint-Paul de Vence
          </h2>
          <div class="prose-content text-base md:text-lg">
            <p>
              Au cœur de la Côte d'Azur, entre Cannes et Nice, à proximité du village fortifié de Saint-Paul de Vence, le Mas du Chanoine vous propose des chambres d'hôtes de charme, à 15 minutes des plages de Cagnes-sur-Mer et d'Antibes.
            </p>
            <p>
              Dans cet environnement d'exception, vous bénéficierez de prestations haut de gamme et de services personnalisés.
            </p>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] rounded-sm overflow-hidden shadow-lg">
            <img
              src="/media/mas-du-chanoine-jardin.jpg"
              alt="Le jardin du Mas du Chanoine à Saint-Paul de Vence"
              class="w-full h-full object-cover"
              loading="lazy"
              width="800"
              height="600"
            />
          </div>
          <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-accent-50 rounded-sm -z-10 hidden md:block"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Rooms Section -->
  <section class="section-pad bg-primary-50" id="chambres">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <p class="text-sm tracking-[0.2em] uppercase text-accent-600 mb-3 font-medium">Hébergement</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-primary-900">Nos chambres d'hôtes</h2>
        <p class="mt-4 text-primary-600 max-w-2xl mx-auto">
          Trois chambres d'hôtes spacieuses aux prestations luxueuses et une suite familiale « Le Petit Mas », toutes décorées dans la tradition provençale.
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {rooms.map((room) => (
          <a href={room.slug} class="group bg-white rounded-sm overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300">
            <div class="aspect-[3/2] overflow-hidden">
              <img
                src={room.image}
                alt={`Chambre d'hôtes ${room.name} au Mas du Chanoine`}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                width="600"
                height="400"
              />
            </div>
            <div class="p-6 md:p-8">
              <p class="text-xs tracking-[0.2em] uppercase text-accent-600 mb-1 font-medium">{room.tagline}</p>
              <h3 class="text-xl md:text-2xl font-serif font-semibold text-primary-900 mb-2 group-hover:text-accent-600 transition-colors">{room.name}</h3>
              <p class="text-sm text-primary-600 mb-3">{room.description}</p>
              <p class="text-xs text-primary-400">{room.details}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/chambres-dhotes/" class="btn-outline">Voir toutes les chambres</a>
      </div>
    </div>
  </section>

  <!-- Hosts Section -->
  <section class="section-pad">
    <div class="container-narrow">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="order-2 lg:order-1 relative">
          <div class="aspect-[4/3] rounded-sm overflow-hidden shadow-lg">
            <img
              src="/media/pascale-yves.jpg"
              alt="Pascale et Yves, vos hôtes au Mas du Chanoine"
              class="w-full h-full object-cover"
              loading="lazy"
              width="800"
              height="600"
            />
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <p class="text-sm tracking-[0.2em] uppercase text-accent-600 mb-3 font-medium">Vos hôtes</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-6 text-primary-900 leading-tight">
            Pascale et Yves
          </h2>
          <div class="prose-content text-base md:text-lg">
            <p>
              vous accueillent dans une ambiance conviviale, raffinée et reposante.
            </p>
            <p>
              Grâce à leur connaissance de la région, ils seront de véritables ambassadeurs pour vous faire découvrir la Côte d'Azur et la Provence.
            </p>
            <p>
              Leurs conseils feront de votre séjour un souvenir inoubliable. À votre demande, ils effectueront les réservations de restaurants, de plages privées…
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section-pad bg-accent-50/50">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <p class="text-sm tracking-[0.2em] uppercase text-accent-600 mb-3 font-medium">Témoignages</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-primary-900">Livre d'or & Témoignages</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {testimonials.map((t) => (
          <blockquote class="bg-white rounded-sm p-8 shadow-sm">
            <svg class="w-8 h-8 text-accent-200 mb-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
            <p class="text-sm text-primary-700 leading-relaxed italic mb-6">{t.text}</p>
            <footer class="text-sm">
              <cite class="not-italic font-semibold text-primary-900">{t.author}</cite>
              <span class="text-primary-400"> — {t.origin}</span>
            </footer>
          </blockquote>
        ))}
      </div>
      <div class="text-center mt-10 flex flex-col items-center gap-6">
        <a href="/avis-des-hotes" class="text-accent-600 hover:text-accent-700 text-sm font-medium underline underline-offset-4">
          Voir tous les avis →
        </a>
        <img
          src="/media/tripadvisor-excellence.png"
          alt="Certificat d'Excellence TripAdvisor"
          class="h-24 w-auto"
          loading="lazy"
          width="160"
          height="160"
        />
      </div>
    </div>
  </section>

  <!-- Practical Info -->
  <section class="section-pad">
    <div class="container-narrow">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="text-sm tracking-[0.2em] uppercase text-accent-600 mb-3 font-medium">Informations pratiques</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-8 text-primary-900">Votre séjour</h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-primary-900 font-sans text-sm">Petit-déjeuner</h3>
                <p class="text-sm text-primary-600">Inclus, servi dans le patio ou le jardin</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-primary-900 font-sans text-sm">Localisation</h3>
                <p class="text-sm text-primary-600">À proximité de Saint-Paul de Vence, 15 min des plages</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-primary-900 font-sans text-sm">Parking gratuit</h3>
                <p class="text-sm text-primary-600">Stationnement privé dans la propriété</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.858 15.355-5.858 21.213 0" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-primary-900 font-sans text-sm">Wi-Fi gratuit</h3>
                <p class="text-sm text-primary-600">Connexion haut débit dans toutes les chambres</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-primary-900 font-sans text-sm">Piscine</h3>
                <p class="text-sm text-primary-600">Bassin de 12m × 6m avec espace aménagé</p>
              </div>
            </div>
          </div>
        </div>
        <div>
          <div class="bg-primary-50 rounded-sm p-8 md:p-10">
            <h3 class="text-xl font-serif font-semibold text-primary-900 mb-4">Comment nous trouver</h3>
            <address class="not-italic text-primary-700 space-y-2 text-sm mb-6">
              <p class="font-semibold">Le Mas du Chanoine</p>
              <p>831 chemin de la Bastide Rouge</p>
              <p>06570 Saint-Paul de Vence</p>
              <p>Côte d'Azur, France</p>
            </address>
            <div class="space-y-3 text-sm">
              <a href="tel:+33627271649" class="flex items-center gap-2 text-primary-700 hover:text-accent-600 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                +33 (0)6 27 27 16 49
              </a>
              <a href="mailto:pascale@masduchanoine.com" class="flex items-center gap-2 text-primary-700 hover:text-accent-600 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                pascale@masduchanoine.com
              </a>
            </div>
            <div class="mt-8 flex flex-col gap-3">
              <a href="/acces" class="btn-outline text-xs text-center">Voir le plan d'accès</a>
              <a href="https://masduchanoine.thais-hotel.com/hotel/website/reservations.php?lang=fr" target="_blank" rel="noopener noreferrer" class="btn-primary text-xs text-center">
                Réserver maintenant
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 md:py-28 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-[url('/media/piscine-mas-du-chanoine.jpg')] bg-cover bg-center"></div>
