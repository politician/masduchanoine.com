---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const amenities = [
  'Lit King Size',
  'Café Nespresso',
  'Baignoire',
  'Air conditionné',
  'Thé et tisanes',
  'Douche italienne',
  'Wi-Fi gratuit',
  'Mini Bar',
  'WC',
  'TV écran plat',
  'Eau minérale',
  'Sèche-cheveux',
  'Chaînes internationales',
  'Autres boissons en option',
  'Peignoirs',
  'Coffre-fort',
  'Parking gratuit',
  "Produits d'accueil",
  '2 fauteuils',
  'Bureau',
  'Serviettes piscine',
];

const gallery = [
  { src: '/media/chambres/chambre-saint-pauloise.jpg', alt: 'La Saint Pauloise — chambre principale' },
  { src: '/media/chambres/saint-pauloise-armoire.jpg', alt: 'La Saint Pauloise — armoire provençale peinte' },
  { src: '/media/chambres/saint-pauloise-salle-bain.jpg', alt: 'La Saint Pauloise — salle de bain avec baignoire' },
  { src: '/media/chambres/saint-pauloise-entree.jpg', alt: "La Saint Pauloise — entrée depuis l'escalier" },
  { src: '/media/chambres/saint-pauloise-entree-riviera.jpg', alt: 'La Saint Pauloise — entrée de la chambre' },
  { src: '/media/photos/saint-pauloise-1400.jpg', alt: 'La Saint Pauloise — vue panoramique' },
  { src: '/media/chambres/saint-paul-village.jpg', alt: 'Village de Saint-Paul de Vence' },
];
---

<BaseLayout
  title="La Saint Pauloise — Chambre d'hôtes de charme | Mas du Chanoine"
  description="La Saint Pauloise, chambre de maître de 30m² avec vue sur Saint-Paul de Vence. Meubles peints provençaux, baignoire et douche. Chambre d'hôtes Côte d'Azur."
>
  <!-- Hero -->
  <section class="relative py-20 md:py-28 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-[url('/media/chambres/chambre-saint-pauloise.jpg')] bg-cover bg-center"></div>
    <div class="absolute inset-0 bg-primary-950/60"></div>
    <div class="relative z-10 text-center text-white max-w-3xl mx-auto">
      <p class="text-sm tracking-[0.3em] uppercase mb-4 text-primary-200 font-light">Charme & Vue sur le village</p>
      <h1 class="text-4xl md:text-5xl font-serif font-semibold">LA SAINT PAULOISE</h1>
    </div>
  </section>

  <!-- Breadcrumb -->
  <nav class="max-w-6xl mx-auto px-4 md:px-8 py-4 text-sm text-primary-400" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2">
      <li><a href="/" class="hover:text-accent-600 transition-colors">Accueil</a></li>
      <li>›</li>
      <li><a href="/chambres-dhotes/" class="hover:text-accent-600 transition-colors">Chambres</a></li>
      <li>›</li>
      <li class="text-primary-700">La Saint Pauloise</li>
    </ol>
  </nav>

  <!-- Content -->
  <section class="section-pad pt-8">
    <div class="container-narrow">
      <div class="grid lg:grid-cols-5 gap-12">
        <div class="lg:col-span-3 prose-content text-base md:text-lg">
          <p>
            Cette chambre d'hôtes de charme (30&nbsp;m²) située au 1er étage est accessible directement par un escalier depuis le patio extérieur. Elle se trouve dans la partie la plus ancienne du Mas datant du 17ème siècle et elle doit son nom à la vue magnifique qu'elle offre sur le village de Saint-Paul de Vence.
          </p>
          <p>
            Elle fut la chambre du Chanoine et des maîtres de maison successifs. Meublée dans la tradition provençale avec d'authentiques meubles peints, elle offre un confort chaleureux grâce à son parquet de chêne.
          </p>
          <p>
            En plus d'un lit King Size (180×200), vous disposez de deux fauteuils et d'un bureau. La salle de bain très spacieuse et lumineuse comprend une baignoire encastrée dans le sol, une douche et des toilettes. Elle offre une jolie vue sur les montagnes.
          </p>
        </div>
        <aside class="lg:col-span-2">
          <div class="bg-primary-50 rounded-sm p-6 md:p-8 sticky top-24">
            <h2 class="text-lg font-serif font-semibold text-primary-900 mb-2">Caractéristiques</h2>
            <p class="text-sm text-primary-600 mb-6">Surface : 30 m² ― 1 chambre ― 1er étage</p>
            <div class="grid grid-cols-2 gap-3">
              {amenities.map((a) => (
                <div class="flex items-center gap-2 text-sm text-primary-700">
                  <svg class="w-4 h-4 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {a}
                </div>
              ))}
            </div>
            <a
              href="https://masduchanoine.thais-hotel.com/hotel/website/reservations.php?lang=fr"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary w-full text-center mt-8 text-xs"
            >
              Réserver cette chambre
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section-pad bg-primary-50">
    <div class="container-narrow">
      <h2 class="text-2xl md:text-3xl font-serif font-semibold text-primary-900 mb-8 text-center">Galerie photos</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {gallery.map((img) => (
          <div class="aspect-[4/3] rounded-sm overflow-hidden">
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              loading="lazy"
              width="400"
              height="300"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Other rooms -->
  <section class="section-pad">
    <div class="container-narrow text-center">
      <h2 class="text-2xl font-serif font-semibold text-primary-900 mb-6">Découvrir nos autres chambres</h2>
      <a href="/chambres-dhotes/" class="btn-outline">Voir toutes les chambres</a>
    </div>
  </section>
</BaseLayout>
