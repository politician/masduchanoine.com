---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Come raggiungerci — Mas du Chanoine" description="Come arrivare al Mas du Chanoine a Saint-Paul de Vence. 831 chemin de la Bastide Rouge." lang="it">
  <section class="relative py-20 md:py-28 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-primary-100"></div>
    <div class="relative z-10 text-center max-w-3xl mx-auto">
      <p class="text-sm tracking-[0.3em] uppercase mb-4 text-accent-600 font-light">Informazioni pratiche</p>
      <h1 class="text-4xl md:text-5xl font-serif font-semibold text-primary-900">Come raggiungerci</h1>
    </div>
  </section>
  <section class="section-pad">
    <div class="container-narrow">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <div class="aspect-[4/3] rounded-sm overflow-hidden shadow-lg">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2883.5!2d7.1134!3d43.6949!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sLe+Mas+du+Chanoine!5e0!3m2!1sit!2sfr!4v1234567890" width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy" title="Posizione del Mas du Chanoine"></iframe>
          </div>
        </div>
        <div>
          <div class="bg-primary-50 rounded-sm p-8 md:p-10 mb-8">
            <h2 class="text-xl font-serif font-semibold text-primary-900 mb-4">Il nostro indirizzo</h2>
            <address class="not-italic text-primary-700 space-y-2 mb-6">
              <p class="font-semibold text-lg">Le Mas du Chanoine</p>
              <p>831 chemin de la Bastide Rouge</p>
              <p>06570 Saint-Paul de Vence</p>
              <p>Costa Azzurra, Francia</p>
            </address>
            <div class="space-y-3 text-sm">
              <a href="tel:+33627271649" class="text-primary-700 hover:text-accent-600">+33 (0)6 27 27 16 49</a><br/>
              <a href="mailto:pascale@masduchanoine.com" class="text-primary-700 hover:text-accent-600">pascale@masduchanoine.com</a>
            </div>
          </div>
          <div class="space-y-6">
            <div><h3 class="font-serif font-semibold text-primary-900 mb-2">In auto</h3><p class="text-sm text-primary-600">Dall'autostrada A8, prendere l'uscita Cagnes-sur-Mer poi seguire la direzione Saint-Paul de Vence.</p></div>
            <div><h3 class="font-serif font-semibold text-primary-900 mb-2">In aereo</h3><p class="text-sm text-primary-600">L'aeroporto più vicino è l'aeroporto di Nizza Costa Azzurra, a circa 20 minuti di auto.</p></div>
            <div><h3 class="font-serif font-semibold text-primary-900 mb-2">Parcheggio</h3><p class="text-sm text-primary-600">Parcheggio privato gratuito nella proprietà.</p></div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
