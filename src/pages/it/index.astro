---
import BaseLayout from '../../layouts/BaseLayout.astro';

const highlights = [
  { icon: '🏘️', title: 'Saint-Paul de Vence', text: 'Autentico villaggio medievale, famoso nel mondo, frequentato da artisti' },
  { icon: '🏛️', title: 'Casa del 17° secolo', text: 'Una casa piena di storia con comfort moderni e accoglienti' },
  { icon: '🛏️', title: 'Solo 4 suite', text: 'Ambiente intimo, accogliente e rilassante' },
  { icon: '🏊', title: 'Piscina con vista', text: 'Piscina 12m × 6m circondata da un giardino paesaggistico' },
  { icon: '🎯', title: 'Servizio personalizzato', text: 'Conciergerie, organizzazione delle vostre giornate, prenotazione dei ristoranti' },
];

const rooms = [
  { name: 'Cannoise Camera', slug: '/it/chambres-hotes/cannoise-camera/', tagline: 'Provenzale Chic', description: 'Baciata dal sole, in stile provenzale chic e alla moda star di Cannes, con vista sulla piscina', details: 'Suite junior · 36 m² · 2 persone · Letto King Size · Doccia all\'italiana', image: '/media/chambres/chambre-cannoise.jpg' },
  { name: 'Niçoise Camera', slug: '/it/chambres-hotes/nicoise-camera/', tagline: 'Spaziosa & Accogliente', description: 'Sotto l\'albero di limone, in stile provenzale, il fascino della vecchia Nizza', details: 'Suite junior · 36 m² · 2 persone · Letto King Size o letti singoli · Doccia all\'italiana', image: '/media/chambres/chambre-nicoise.jpg' },
  { name: 'Saint Pauloise Camera', slug: '/it/chambres-hotes/saint-pauloise-camera/', tagline: 'Charme & Vista', description: 'La camera da letto principale si affaccia sul villaggio di Saint-Paul de Vence', details: '1° piano · 30 m² · 2 persone · Letto King Size · Vasca e doccia', image: '/media/chambres/chambre-saint-pauloise.jpg' },
  { name: 'Petit Mas Suite Familiare', slug: '/it/chambres-hotes/petit-mas-familiare-suite/', tagline: 'Indipendente & Familiare', description: 'Casetta autonoma con 2 camere da letto, per chi viaggia in famiglia', details: 'Suite familiare · 35 m² · 3 persone · 2 camere · Doccia all\'italiana', image: '/media/chambres/chambre-petit-mas.jpg' },
];

const testimonials = [
  { text: 'Purtroppo oggi si parte, dopo una settimana di vacanza a "La Mas du Chanoine" che ricorderemo per sempre. Ci sembra di essere stati ospiti a casa di Pascale e Yves. Due padroni di casa ospitali e veramente gentili. Grazie di tutto! Ritorneremo con affetto.', author: 'Federica e Paolo', origin: 'Roma' },
  { text: 'Grazie per la vostra ospitalità, siete delle persone meravigliose. Come tutto quello che vi circonda riempie gli occhi di gioia. Grazie ancora di tutto, a presto.', author: 'Nicoletta e Roberto', origin: 'Italia' },
  { text: 'Grazie per la vostra splendida ospitalità! Siamo stati benissimo nella calma del Mas du Chanoine. Magnifico!', author: 'Paolo, Roberta, Anita', origin: 'Italia' },
];
---

<BaseLayout title="Mas du Chanoine — B&B di charme a Saint-Paul de Vence, Costa Azzurra" description="Al centro della Costa Azzurra, tra Cannes e Nizza, il Mas du Chanoine vi propone camere in un B&B di charme a Saint-Paul de Vence." lang="it">
  <section class="relative h-[85vh] min-h-[600px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-primary-950/60 via-primary-950/40 to-primary-950/70 z-10"></div>
    <div class="absolute inset-0" id="hero-slider">
      <div class="absolute inset-0 bg-cover bg-center transition-opacity duration-1000 opacity-100" style="background-image: url('/media/slider-vue-mas.jpg')"></div>
      <div class="absolute inset-0 bg-cover bg-center transition-opacity duration-1000 opacity-0" style="background-image: url('/media/slider-piscine.jpg')"></div>
      <div class="absolute inset-0 bg-cover bg-center transition-opacity duration-1000 opacity-0" style="background-image: url('/media/slider-bassin.jpg')"></div>
    </div>
    <div class="relative z-20 text-center text-white px-4 max-w-4xl mx-auto">
      <p class="text-sm md:text-base tracking-[0.3em] uppercase mb-4 text-primary-200 font-light">Saint-Paul de Vence · Costa Azzurra</p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-serif font-semibold mb-6 leading-tight">Mas du Chanoine</h1>
      <p class="text-lg md:text-xl font-light mb-10 max-w-2xl mx-auto text-primary-100 leading-relaxed">B&B di charme in una casa del 17° secolo, tra Cannes e Nizza</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://masduchanoine.thais-hotel.com/hotel/website/reservations.php?lang=it" target="_blank" rel="noopener noreferrer" class="btn-primary bg-white text-primary-900 hover:bg-primary-100">Prenota ora</a>
        <a href="/it/bed-e-breakfast/" class="btn-outline border-white text-white hover:bg-white hover:text-primary-900">Scopri le camere</a>
      </div>
    </div>
  </section>

  <section class="bg-primary-50 border-y border-primary-100">
    <div class="max-w-7xl mx-auto px-4 md:px-8 py-12">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8 text-center">
        {highlights.map((h) => (
          <div class="space-y-2">
            <span class="text-3xl" aria-hidden="true">{h.icon}</span>
            <h2 class="font-serif font-semibold text-sm md:text-base text-primary-900">{h.title}</h2>
            <p class="text-xs md:text-sm text-primary-600 leading-relaxed">{h.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-sm tracking-[0.2em] uppercase text-accent-600 mb-3 font-medium">Benvenuti</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-6 text-primary-900 leading-tight">B&B di charme a Saint-Paul de Vence</h2>
          <div class="prose-content text-base md:text-lg">
            <p>Tra Saint-Paul de Vence e Haut de Cagnes, il nostro B&B le Mas du Chanoine è situato nel cuore della Costa Azzurra, a meno di dieci minuti dalle spiagge di Antibes e di Cagnes-sur-Mer.</p>
            <p>In questo ambiente straordinario, con prestazioni di alta qualità, vi potrete rilassare nel giardino fiorito oppure in piscina.</p>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] rounded-sm overflow-hidden shadow-lg"><img src="/media/mas-du-chanoine-jardin.jpg" alt="Il giardino del Mas du Chanoine" class="w-full h-full object-cover" loading="lazy" width="800" height="600" /></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad bg-primary-50">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <p class="text-sm tracking-[0.2em] uppercase text-accent-600 mb-3 font-medium">Alloggio</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-primary-900">Le nostre camere</h2>
        <p class="mt-4 text-primary-600 max-w-2xl mx-auto">Vi proponiamo tre camere e una suite familiare, raffinate con prestazioni di lusso, arredate secondo la tradizione provenzale.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {rooms.map((room) => (
          <a href={room.slug} class="group bg-white rounded-sm overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300">
            <div class="aspect-[3/2] overflow-hidden"><img src={room.image} alt={`${room.name} al Mas du Chanoine`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="600" height="400" /></div>
            <div class="p-6 md:p-8">
              <p class="text-xs tracking-[0.2em] uppercase text-accent-600 mb-1 font-medium">{room.tagline}</p>
              <h3 class="text-xl md:text-2xl font-serif font-semibold text-primary-900 mb-2 group-hover:text-accent-600 transition-colors">{room.name}</h3>
              <p class="text-sm text-primary-600 mb-3">{room.description}</p>
              <p class="text-xs text-primary-400">{room.details}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="order-2 lg:order-1 relative">
          <div class="aspect-[4/3] rounded-sm overflow-hidden shadow-lg"><img src="/media/pascale-yves.jpg" alt="Pascale e Yves, i vostri ospiti al Mas du Chanoine" class="w-full h-full object-cover" loading="lazy" /></div>
        </div>
        <div class="order-1 lg:order-2">
          <p class="text-sm tracking-[0.2em] uppercase text-accent-600 mb-3 font-medium">I vostri ospiti</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-6 text-primary-900 leading-tight">Pascale e Yves</h2>
          <div class="prose-content text-base md:text-lg">
            <p>I vostri ospiti, Pascale e Yves vi accoglieranno in un'atmosfera cordiale, raffinata e rilassante.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad bg-accent-50/50">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <p class="text-sm tracking-[0.2em] uppercase text-accent-600 mb-3 font-medium">Recensioni</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-primary-900">Libro d'oro</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {testimonials.map((t) => (
          <blockquote class="bg-white rounded-sm p-8 shadow-sm">
            <svg class="w-8 h-8 text-accent-200 mb-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" /></svg>
            <p class="text-sm text-primary-700 leading-relaxed italic mb-6">{t.text}</p>
            <footer class="text-sm"><cite class="not-italic font-semibold text-primary-900">{t.author}</cite><span class="text-primary-400"> — {t.origin}</span></footer>
          </blockquote>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/it/recensioni/" class="text-accent-600 hover:text-accent-700 text-sm font-medium underline underline-offset-4">Leggere tutte le recensioni →</a>
      </div>
    </div>
  </section>

  <section class="relative py-20 md:py-28 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-[url('/media/piscine-mas-du-chanoine.jpg')] bg-cover bg-center"></div>
    <div class="absolute inset-0 bg-primary-950/70"></div>
    <div class="relative z-10 text-center text-white max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-6">Prenota il tuo soggiorno</h2>
      <p class="text-lg text-primary-200 mb-10">Concedetevi un soggiorno eccezionale sulla Costa Azzurra, nell'ambiente intimo del Mas du Chanoine.</p>
      <a href="https://masduchanoine.thais-hotel.com/hotel/website/reservations.php?lang=it" target="_blank" rel="noopener noreferrer" class="btn-primary bg-white text-primary-900 hover:bg-primary-100">Prenota al miglior prezzo</a>
    </div>
  </section>

  <script>
    const slider = document.getElementById('hero-slider');
    if (slider) {
      const slides = slider.querySelectorAll<HTMLElement>('[class*="transition-opacity"]');
      let current = 0;
      setInterval(() => { slides[current].style.opacity = '0'; current = (current + 1) % slides.length; slides[current].style.opacity = '1'; }, 5000);
    }
  </script>
</BaseLayout>
