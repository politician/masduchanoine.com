  'Asciugacapelli', 'TV a schermo piatto', 'Acqua minerale', 'Accappatoi',
  'Canali internazionali', 'Bevande in supplemento', 'Pantofole', 'Cassaforte',
  'Mobili da giardino', 'Kit di cortesia', 'Area salotto', 'Parcheggio gratuito',
  'Asciugamani piscina', 'Scrivania',
];

const gallery = [
  { src: '/media/chambres/chambre-cannoise.jpg', alt: 'La Cannoise — camera principale' },
  { src: '/media/chambres/cannoise-palme-festival.jpg', alt: 'La Cannoise — decorazione Festival di Cannes' },
  { src: '/media/chambres/cannoise-salon-jardin.jpg', alt: 'La Cannoise — arredamento da giardino' },
  { src: '/media/chambres/cannoise-bureau-salon.jpg', alt: 'La Cannoise — scrivania e area salotto' },
  { src: '/media/chambres/cannoise-douche.jpg', alt: 'La Cannoise — bagno con doccia' },
