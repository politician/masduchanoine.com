---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Prezzi — Mas du Chanoine" description="Prezzi delle camere al Mas du Chanoine, Saint-Paul de Vence, Costa Azzurra." lang="it">
  <section class="relative py-20 md:py-28 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-primary-100"></div>
    <div class="relative z-10 text-center max-w-3xl mx-auto">
      <p class="text-sm tracking-[0.3em] uppercase mb-4 text-accent-600 font-light">Stagione 2026</p>
      <h1 class="text-4xl md:text-5xl font-serif font-semibold text-primary-900">Prezzi</h1>
    </div>
  </section>
  <section class="section-pad">
    <div class="container-narrow"><div class="max-w-3xl mx-auto text-center prose-content">
      <p class="text-lg">Questa pagina è disponibile solo in <a href="/tarifs/">francese</a> e in <a href="/en/rates/">inglese</a>.</p>
      <div class="mt-8">
        <a href="https://masduchanoine.thais-hotel.com/hotel/website/reservations.php?lang=it" target="_blank" rel="noopener noreferrer" class="btn-primary">Prenota ora</a>
      </div>
    </div></div>
  </section>
</BaseLayout>
