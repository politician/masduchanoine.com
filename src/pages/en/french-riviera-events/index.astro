---

<BaseLayout title="Events on the French Riviera — Mas du Chanoine" description="Discover events, festivals and activities on the French Riviera. Guide to outings near Mas du Chanoine, Saint-Paul de Vence." lang="en">
  <section class="relative py-20 md:py-28 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-primary-100"></div>
    <div class="relative z-10 text-center max-w-3xl mx-auto">
      <p class="text-sm tracking-[0.3em] uppercase mb-4 text-accent-600 font-light">Blog & News</p>
      <h1 class="text-4xl md:text-5xl font-serif font-semibold text-primary-900">Events on the French Riviera</h1>
    </div>
  </section>
  <section class="section-pad">
    <div class="container-narrow">
      <div class="grid lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <div class="grid md:grid-cols-2 gap-8">
            {articles.map((article) => (
              <article class="bg-white border border-primary-100 rounded-sm overflow-hidden hover:shadow-lg transition-shadow duration-300">
                <div class="p-6">
                  <time class="text-xs text-primary-400 tracking-wider uppercase">{article.date}</time>
                  <h2 class="text-lg font-serif font-semibold text-primary-900 mt-2 mb-3 leading-snug">
                    <a href={article.slug} class="hover:text-accent-600 transition-colors">{article.title}</a>
                  </h2>
                  <div class="flex flex-wrap gap-2 mb-3">
                    {article.categories.map((cat) => (<span class="text-[11px] tracking-wider uppercase px-2 py-0.5 bg-accent-50 text-accent-700 rounded-sm font-medium">{cat}</span>))}
                  </div>
                  <a href={article.slug} class="inline-flex items-center text-sm font-medium text-accent-600 hover:text-accent-700 transition-colors">Read more <span class="ml-1">→</span></a>
                </div>
              </article>
            ))}
          </div>
        </div>
        <aside class="lg:col-span-1"><Sidebar /></aside>
      </div>
    </div>
  </section>
</BaseLayout>
