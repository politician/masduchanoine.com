---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const activities = [
  { image: '/media/activites/saint-paul.jpg', title: 'Saint-Paul de Vence', subtitle: "Artists' village", link: '/en/activites/st-paul-de-vence/' },
  { image: '/media/activites/nice.jpg', title: 'Nice', subtitle: 'Capital of the French Riviera', link: '/en/activites/nice/' },
  { image: '/media/activites/antibes.jpg', title: 'Antibes & Cap d\'Antibes', subtitle: 'Old town and beaches', link: '/en/activites/antibes-and-cap-dantibes/' },
  { image: '/media/activites/cannes.jpg', title: 'Cannes & Lérins Islands', subtitle: 'Two atmospheres', link: '/en/activites/cannes-and-lerins-islands/' },
  { image: '/media/activites/monaco.jpg', title: 'Monaco', subtitle: 'Monte-Carlo', link: '/en/activites/monaco/' },
  { image: '/media/activites/villages.jpg', title: 'Hilltop Villages', subtitle: 'Gourdon, Tourrettes-sur-Loup & Eze', link: '/en/activites/hilltop-villages/' },
  { image: '/media/activites/golf.jpg', title: 'Golf', subtitle: 'Ten courses', link: '/en/activites/golf-en/' },
  { image: '/media/activites/cuisine.jpg', title: 'Cooking Lessons', subtitle: 'Two formulas', link: '/en/activites/cooking-lessons/' },
  { image: '/media/activites/shiatsu.jpg', title: 'Shiatsu', subtitle: 'By reservation', link: '/en/activites/shiatsu-en/' },
];
---

<BaseLayout title="Activities on the French Riviera — Mas du Chanoine" description="Discover activities and visits from Mas du Chanoine: Saint-Paul de Vence, Nice, Cannes, Monaco, hilltop villages, golf and more." lang="en">
  <section class="relative h-[50vh] min-h-[400px] flex items-end overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-t from-primary-950/70 via-primary-950/30 to-primary-950/10 z-10"></div>
    <img src="/media/piscine-espace-fleuri.jpg" alt="View from Mas du Chanoine over the French Riviera" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    <div class="relative z-20 text-white px-4 md:px-8 pb-12 max-w-4xl">
      <p class="text-sm tracking-[0.3em] uppercase mb-3 text-primary-200 font-light">To discover</p>
      <h1 class="text-4xl md:text-5xl font-serif font-semibold leading-tight">Activities on the French Riviera</h1>
      <p class="text-lg text-primary-200 mt-4 max-w-2xl">From Mas du Chanoine, set out to discover the most beautiful sites of the French Riviera.</p>
    </div>
  </section>
  <section class="section-pad">
    <div class="container-narrow">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {activities.map((activity) => (
          <a href={activity.link} class="group relative block rounded-sm overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500">
            <div class="aspect-[3/2] overflow-hidden"><img src={activity.image} alt={`${activity.title} — ${activity.subtitle}`} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" loading="lazy" /></div>
            <div class="absolute inset-0 bg-gradient-to-t from-primary-950/80 via-primary-950/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5 md:p-6 text-white">
              <p class="text-xs tracking-[0.15em] uppercase text-primary-300 mb-1 font-light">{activity.subtitle}</p>
              <h2 class="text-xl md:text-2xl font-serif font-semibold leading-tight group-hover:text-accent-200 transition-colors duration-300">{activity.title}</h2>
              <span class="inline-block mt-2 text-sm text-primary-300 group-hover:text-white group-hover:translate-x-1 transition-all duration-300">Discover →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
  <section class="section-pad bg-primary-900 text-white text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-4">Explore the French Riviera from the Mas</h2>
      <p class="text-primary-300 mb-8 text-lg">Book your stay and let us guide you.</p>
      <a href="https://masduchanoine.thais-hotel.com/hotel/website/reservations.php?lang=en" target="_blank" rel="noopener noreferrer" class="btn-primary bg-white text-primary-900 hover:bg-primary-100">Book now</a>
    </div>
  </section>
</BaseLayout>
