  'Hair dryer', 'Flat screen TV', 'Mineral water', 'Bathrobes',
  'Air conditioning', 'Optional beverages', 'Slippers', 'Safe',
  'Outdoor area', "Local amenities", 'Armchair in Queen room', 'Free Parking',
  'Pool towels', 'Desk in King room',
];

const gallery = [
  { src: '/media/chambres/chambre-petit-mas.jpg', alt: 'Le Petit Mas — exterior view' },
  { src: '/media/chambres/petit-mas-chambre-queen.jpg', alt: 'Le Petit Mas — Queen bedroom' },
  { src: '/media/chambres/petit-mas-vue-exterieure.jpg', alt: 'Le Petit Mas — facade and garden' },
