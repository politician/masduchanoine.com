---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact Us — Mas du Chanoine" description="Contact Mas du Chanoine for availability or room reservation at our bed and breakfast in Saint-Paul de Vence." lang="en">
  <section class="relative py-20 md:py-28 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-primary-100"></div>
    <div class="relative z-10 text-center max-w-3xl mx-auto">
      <p class="text-sm tracking-[0.3em] uppercase mb-4 text-accent-600 font-light">Get in touch</p>
      <h1 class="text-4xl md:text-5xl font-serif font-semibold text-primary-900">Contact Us</h1>
    </div>
  </section>
  <section class="section-pad">
    <div class="container-narrow">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        <div>
          <h2 class="text-2xl md:text-3xl font-serif font-semibold text-primary-900 mb-6">Availability enquiries</h2>
          <p class="text-primary-600 mb-8 leading-relaxed text-base md:text-lg">For any availability or booking enquiry, please contact us by phone, email or WhatsApp. Pascale and Yves will be delighted to assist you.</p>
          <div class="space-y-6 mb-10">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-accent-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <div><h3 class="font-semibold text-primary-900 mb-1">Phone</h3><a href="tel:+33627271649" class="text-accent-600 hover:text-accent-700 text-lg font-medium">+33 (0)6 27 27 16 49</a></div>
            </div>
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-accent-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
              <div><h3 class="font-semibold text-primary-900 mb-1">Email</h3><a href="mailto:pascale@masduchanoine.com" class="text-accent-600 hover:text-accent-700 text-lg font-medium">pascale@masduchanoine.com</a></div>
            </div>
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-accent-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <div><h3 class="font-semibold text-primary-900 mb-1">Address</h3><address class="not-italic text-primary-600"><p>831 chemin de la Bastide Rouge</p><p>06570 Saint-Paul de Vence</p><p>French Riviera, France</p></address></div>
            </div>
          </div>
          <div class="bg-accent-600 text-white rounded-sm p-6 md:p-8">
            <h3 class="text-xl font-serif font-semibold mb-3">Book directly</h3>
            <p class="text-white/80 text-sm mb-4 leading-relaxed">You can also book directly through our online booking engine. Best rate guaranteed when booking directly.</p>
            <a href="https://masduchanoine.thais-hotel.com/hotel/website/reservations.php?lang=en" target="_blank" rel="noopener noreferrer" class="btn-primary bg-white text-primary-900 hover:bg-primary-100">Book now</a>
          </div>
        </div>
        <div>
          <div class="aspect-[4/3] rounded-sm overflow-hidden shadow-lg mb-6">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2885.6!2d7.0584!3d43.6951!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12cdd1f0c5e1e29f%3A0x5f5b5b5b5b5b5b5b!2sMas%20du%20Chanoine!5e0!3m2!1sen!2sfr!4v1" width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Location of Mas du Chanoine"></iframe>
          </div>
          <div class="mt-8 bg-primary-50 rounded-sm p-6 md:p-8">
            <h3 class="font-serif font-semibold text-primary-900 mb-4 text-lg">Practical information</h3>
            <div class="space-y-3 text-sm text-primary-600">
              <div class="flex items-start gap-3"><span class="text-accent-600 font-semibold mt-0.5">→</span><p><strong class="text-primary-900">Check-in:</strong> between 5pm and 7pm</p></div>
              <div class="flex items-start gap-3"><span class="text-accent-600 font-semibold mt-0.5">→</span><p><strong class="text-primary-900">Check-out:</strong> before 11am</p></div>
              <div class="flex items-start gap-3"><span class="text-accent-600 font-semibold mt-0.5">→</span><p><strong class="text-primary-900">Parking:</strong> free on the property</p></div>
              <div class="flex items-start gap-3"><span class="text-accent-600 font-semibold mt-0.5">→</span><p><strong class="text-primary-900">Breakfast:</strong> included</p></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
