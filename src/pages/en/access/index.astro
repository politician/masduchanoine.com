---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Access — How to reach Mas du Chanoine, Saint-Paul de Vence" description="Directions and access to Mas du Chanoine in Saint-Paul de Vence. 831 chemin de la Bastide Rouge, between Nice and Cannes on the French Riviera." lang="en">
  <section class="relative py-20 md:py-28 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-primary-100"></div>
    <div class="relative z-10 text-center max-w-3xl mx-auto">
      <p class="text-sm tracking-[0.3em] uppercase mb-4 text-accent-600 font-light">Practical information</p>
      <h1 class="text-4xl md:text-5xl font-serif font-semibold text-primary-900">Access</h1>
    </div>
  </section>
  <section class="section-pad">
    <div class="container-narrow">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <div class="aspect-[4/3] rounded-sm overflow-hidden shadow-lg">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2883.5!2d7.1134!3d43.6949!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sLe+Mas+du+Chanoine!5e0!3m2!1sen!2sfr!4v1234567890" width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Location of Mas du Chanoine"></iframe>
          </div>
          <div class="mt-4">
            <a href="https://www.google.com/maps/search/le+mas+du+chanoine+st+paul+de+vence" target="_blank" rel="noopener noreferrer" class="text-accent-600 hover:text-accent-700 text-sm font-medium underline underline-offset-4">Open in Google Maps →</a>
          </div>
        </div>
        <div>
          <div class="bg-primary-50 rounded-sm p-8 md:p-10 mb-8">
            <h2 class="text-xl font-serif font-semibold text-primary-900 mb-4">Our address</h2>
            <address class="not-italic text-primary-700 space-y-2 mb-6">
              <p class="font-semibold text-lg">Le Mas du Chanoine</p>
              <p>831 chemin de la Bastide Rouge</p>
              <p>06570 Saint-Paul de Vence</p>
              <p>French Riviera, France</p>
            </address>
            <div class="space-y-3 text-sm">
              <a href="tel:+33627271649" class="flex items-center gap-2 text-primary-700 hover:text-accent-600 transition-colors">+33 (0)6 27 27 16 49</a>
              <a href="mailto:pascale@masduchanoine.com" class="flex items-center gap-2 text-primary-700 hover:text-accent-600 transition-colors">pascale@masduchanoine.com</a>
            </div>
          </div>
          <div class="space-y-6">
            <div><h3 class="font-serif font-semibold text-primary-900 mb-2">By car</h3><p class="text-sm text-primary-600 leading-relaxed">From the A8 motorway (La Provençale), take the Cagnes-sur-Mer exit then follow the direction of Saint-Paul de Vence.</p></div>
            <div><h3 class="font-serif font-semibold text-primary-900 mb-2">By plane</h3><p class="text-sm text-primary-600 leading-relaxed">The nearest airport is Nice Côte d'Azur Airport, about 20 minutes by car. Transfer available on request.</p></div>
            <div><h3 class="font-serif font-semibold text-primary-900 mb-2">By train</h3><p class="text-sm text-primary-600 leading-relaxed">The nearest stations are Nice-Ville and Cagnes-sur-Mer. From there, take a taxi or bus to Saint-Paul de Vence.</p></div>
            <div><h3 class="font-serif font-semibold text-primary-900 mb-2">Parking</h3><p class="text-sm text-primary-600 leading-relaxed">Free private parking on the property.</p></div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
