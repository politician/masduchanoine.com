---
import BaseLayout from '../../layouts/BaseLayout.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BedAndBreakfast",
  "name": "Mas du Chanoine",
  "description": "Charming bed and breakfast in Saint-Paul de Vence, French Riviera. 17th century Provençal house with pool, 4 luxury suites, between Nice and Cannes.",
  "url": "https://masduchanoine.com/en/",
  "telephone": "+33627271649",
  "email": "pascale@masduchanoine.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "831 chemin de la Bastide Rouge",
    "addressLocality": "Saint-Paul de Vence",
    "postalCode": "06570",
    "addressRegion": "French Riviera",
    "addressCountry": "FR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 43.7,
    "longitude": 7.11
  },
  "image": "https://masduchanoine.com/media/hero-mas-du-chanoine.jpg",
  "priceRange": "€€€",
  "starRating": {
    "@type": "Rating",
    "ratingValue": "5"
  },
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Swimming Pool", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Free Wi-Fi", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Free Parking", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Breakfast Included", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Air Conditioning", "value": true }
  ],
  "sameAs": [
    "https://www.facebook.com/MasDuChanoine/",
    "https://www.instagram.com/masduchanoine/",
    "https://twitter.com/masduchanoine"
  ]
};

const rooms = [
  {
    name: 'Cannoise Guestroom',
    slug: '/en/chambres-hotes/cannoise-guestroom/',
    tagline: 'Provençal Chic & Modern',
    description: 'Sunny room with a view of the fish basin, classy Provençal style with trendy Cannes accents',
    details: 'Junior suite · 388 sq ft · 2 guests · King Size bed · Walk-in shower',
    image: '/media/chambres/chambre-cannoise.jpg',
  },
  {
    name: 'Niçoise Guestroom',
    slug: '/en/chambres-hotes/nicoise-guestroom/',
    tagline: 'Spacious & Cosy',
    description: 'Room under the lemon tree, with a view of the fish basin, Provençal style, the charm of Old Nice',
    details: 'Junior suite · 388 sq ft · 2 guests · King Size or twin beds · Walk-in shower',
    image: '/media/chambres/chambre-nicoise.jpg',
  },
  {
    name: 'Saint Pauloise Guestroom',
    slug: '/en/chambres-hotes/saint-pauloise-guestroom/',
    tagline: 'Charm & Village View',
    description: 'In the oldest part of the Mas, master bedroom overlooking the village of Saint-Paul de Vence',
    details: '1st floor · 323 sq ft · 2 guests · King Size bed · Bathtub & shower',
    image: '/media/chambres/chambre-saint-pauloise.jpg',
  },
  {
    name: 'Petit Mas Family Suite',
    slug: '/en/chambres-hotes/petit-mas-family-suite/',
    tagline: 'Independent & Family',
    description: 'Small independent cottage with 2 bedrooms, for three people traveling together, with a view of the fish basin',
    details: 'Family suite · 377 sq ft · 3 guests · 2 bedrooms · Walk-in shower',
    image: '/media/chambres/chambre-petit-mas.jpg',
  },
];

const highlights = [
  { icon: '🏘️', title: 'Saint-Paul de Vence', text: 'An authentic, world famous, medieval village, loved by many artists' },
  { icon: '🏛️', title: '17th Century House', text: 'A house full of history with charm, warmth and modern comfort' },
  { icon: '🛏️', title: 'Only 4 suites', text: 'Intimate, quiet and relaxing' },
  { icon: '🏊', title: 'Pool with view', text: '14yd × 7yd pool in a fully equipped area' },
  { icon: '🎯', title: 'Personalized service', text: 'Concierge service, daily activities organization, restaurant reservations' },
];

const testimonials = [
  {
    text: 'There are so many wonderful things to say about our stay at your beautiful Mas. We do not know where to begin. Just know we loved meeting you. Your home and our stay has been absolutely perfect in every way. We enjoyed every morning your most delicious breakfasts and especially your homemade cakes.',
    author: 'Lee and Darlene',
    origin: 'USA',
  },
  {
    text: 'Your hospitality has been a beautiful memory we will always remember. Always happy to chat and suggest places to go and places to eat. Mas du Chanoine is a gorgeous house and the room has been superb. A wonderful stay, thank you so much.',
    author: 'Peter and Sue',
    origin: 'Australia',
  },
  {
    text: 'Thank you so much for your warm welcome to your wonderful home. We have so enjoyed every aspect of all that you offer – from the beautiful room with its exquisitely comfortable bed to the delicious breakfasts. The pool and garden are a delight.',
    author: 'Liz and Barrie',
    origin: 'USA',
  },
];
---

<BaseLayout
  title="Mas du Chanoine — Charming B&B in Saint-Paul de Vence, French Riviera"
  description="In the heart of the French Riviera, between Cannes and Nice, Mas du Chanoine offers charming guest rooms in Saint-Paul de Vence. 17th century house, pool, high-end services."
  lang="en"
  structuredData={structuredData}
>
  <!-- Hero Section with Image Slider -->
  <section class="relative h-[85vh] min-h-[600px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-primary-950/60 via-primary-950/40 to-primary-950/70 z-10"></div>
    <div class="absolute inset-0" id="hero-slider">
      <div class="absolute inset-0 bg-cover bg-center transition-opacity duration-1000 opacity-100" style="background-image: url('/media/slider-vue-mas.jpg')"></div>
      <div class="absolute inset-0 bg-cover bg-center transition-opacity duration-1000 opacity-0" style="background-image: url('/media/slider-piscine.jpg')"></div>
      <div class="absolute inset-0 bg-cover bg-center transition-opacity duration-1000 opacity-0" style="background-image: url('/media/slider-bassin.jpg')"></div>
    </div>
    <div class="relative z-20 text-center text-white px-4 max-w-4xl mx-auto">
      <p class="text-sm md:text-base tracking-[0.3em] uppercase mb-4 text-primary-200 font-light">Saint-Paul de Vence · French Riviera</p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-serif font-semibold mb-6 leading-tight">Mas du Chanoine</h1>
      <p class="text-lg md:text-xl font-light mb-10 max-w-2xl mx-auto text-primary-100 leading-relaxed">
        Charming bed and breakfast in a 17<sup>th</sup> century house, between Cannes and Nice
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://masduchanoine.thais-hotel.com/hotel/website/reservations.php?lang=en" target="_blank" rel="noopener noreferrer" class="btn-primary bg-white text-primary-900 hover:bg-primary-100">Book now</a>
        <a href="/en/bed-breakfast/" class="btn-outline border-white text-white hover:bg-white hover:text-primary-900">Discover our rooms</a>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-bounce">
      <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
    </div>
  </section>

  <!-- Highlights Strip -->
  <section class="bg-primary-50 border-y border-primary-100">
    <div class="max-w-7xl mx-auto px-4 md:px-8 py-12">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8 text-center">
        {highlights.map((h) => (
          <div class="space-y-2">
            <span class="text-3xl" aria-hidden="true">{h.icon}</span>
            <h2 class="font-serif font-semibold text-sm md:text-base text-primary-900">{h.title}</h2>
            <p class="text-xs md:text-sm text-primary-600 leading-relaxed">{h.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Image Showcase -->
  <section class="grid md:grid-cols-3 gap-0">
    <div class="aspect-[4/3] md:aspect-auto overflow-hidden">
      <img src="/media/piscine-fleurs.jpg" alt="The pool and its flowers at Mas du Chanoine" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" width="600" height="400" />
    </div>
    <div class="aspect-[4/3] md:aspect-auto overflow-hidden">
      <img src="/media/piscine-espace-fleuri.jpg" alt="The flowered area around the pool" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" width="600" height="400" />
    </div>
    <div class="aspect-[4/3] md:aspect-auto overflow-hidden">
      <img src="/media/hero-mas-du-chanoine.jpg" alt="View of Mas du Chanoine" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" width="600" height="400" />
    </div>
  </section>

  <!-- Presentation -->
  <section class="section-pad">
    <div class="container-narrow">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-sm tracking-[0.2em] uppercase text-accent-600 mb-3 font-medium">Welcome</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-6 text-primary-900 leading-tight">Charming B&B in Saint-Paul de Vence</h2>
          <div class="prose-content text-base md:text-lg">
            <p>In the very heart of the French Riviera, between Cannes and Nice, close to the medieval fortified village of Saint-Paul de Vence, the Mas du Chanoine offers charming guest rooms, only 15 minutes from the beaches of Cagnes-sur-Mer and Antibes.</p>
            <p>In this exceptional location, you will benefit from high-end personalized services.</p>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] rounded-sm overflow-hidden shadow-lg">
            <img src="/media/mas-du-chanoine-jardin.jpg" alt="The garden of Mas du Chanoine in Saint-Paul de Vence" class="w-full h-full object-cover" loading="lazy" width="800" height="600" />
          </div>
          <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-accent-50 rounded-sm -z-10 hidden md:block"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Rooms Section -->
  <section class="section-pad bg-primary-50" id="rooms">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <p class="text-sm tracking-[0.2em] uppercase text-accent-600 mb-3 font-medium">Accommodation</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-primary-900">Our guest rooms</h2>
        <p class="mt-4 text-primary-600 max-w-2xl mx-auto">Three spacious guest rooms with luxury service and a family suite "Le Petit Mas", all decorated in the Provençal tradition.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {rooms.map((room) => (
          <a href={room.slug} class="group bg-white rounded-sm overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300">
            <div class="aspect-[3/2] overflow-hidden">
              <img src={room.image} alt={`${room.name} at Mas du Chanoine`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="600" height="400" />
            </div>
            <div class="p-6 md:p-8">
              <p class="text-xs tracking-[0.2em] uppercase text-accent-600 mb-1 font-medium">{room.tagline}</p>
              <h3 class="text-xl md:text-2xl font-serif font-semibold text-primary-900 mb-2 group-hover:text-accent-600 transition-colors">{room.name}</h3>
              <p class="text-sm text-primary-600 mb-3">{room.description}</p>
              <p class="text-xs text-primary-400">{room.details}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/en/bed-breakfast/" class="btn-outline">View all rooms</a>
      </div>
    </div>
  </section>

  <!-- Hosts Section -->
  <section class="section-pad">
    <div class="container-narrow">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="order-2 lg:order-1 relative">
          <div class="aspect-[4/3] rounded-sm overflow-hidden shadow-lg">
            <img src="/media/pascale-yves.jpg" alt="Pascale and Yves, your hosts at Mas du Chanoine" class="w-full h-full object-cover" loading="lazy" width="800" height="600" />
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <p class="text-sm tracking-[0.2em] uppercase text-accent-600 mb-3 font-medium">Your hosts</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-6 text-primary-900 leading-tight">Pascale and Yves</h2>
          <div class="prose-content text-base md:text-lg">
            <p>welcome you in a friendly, refined and relaxing atmosphere.</p>
            <p>Thanks to their knowledge of the region, they will be true ambassadors to help you discover the French Riviera and Provence.</p>
            <p>Their advice will make your stay truly memorable. At your request, they will make reservations for restaurants, private beaches, etc.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section-pad bg-accent-50/50">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <p class="text-sm tracking-[0.2em] uppercase text-accent-600 mb-3 font-medium">Testimonials</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold text-primary-900">Guest Book & Testimonials</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {testimonials.map((t) => (
          <blockquote class="bg-white rounded-sm p-8 shadow-sm">
            <svg class="w-8 h-8 text-accent-200 mb-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" /></svg>
            <p class="text-sm text-primary-700 leading-relaxed italic mb-6">{t.text}</p>
            <footer class="text-sm">
              <cite class="not-italic font-semibold text-primary-900">{t.author}</cite>
              <span class="text-primary-400"> — {t.origin}</span>
            </footer>
          </blockquote>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/en/testimonials/" class="text-accent-600 hover:text-accent-700 text-sm font-medium underline underline-offset-4">Read all reviews →</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 md:py-28 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-[url('/media/piscine-mas-du-chanoine.jpg')] bg-cover bg-center"></div>
    <div class="absolute inset-0 bg-primary-950/70"></div>
    <div class="relative z-10 text-center text-white max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-6">Book your stay</h2>
      <p class="text-lg text-primary-200 mb-10">Treat yourself to an exceptional stay on the French Riviera, in the intimate setting of Mas du Chanoine.</p>
      <a href="https://masduchanoine.thais-hotel.com/hotel/website/reservations.php?lang=en" target="_blank" rel="noopener noreferrer" class="btn-primary bg-white text-primary-900 hover:bg-primary-100">Choose & Book at the best rate</a>
    </div>
  </section>

  <script>
    const slider = document.getElementById('hero-slider');
    if (slider) {
      const slides = slider.querySelectorAll<HTMLElement>('[class*="transition-opacity"]');
      let current = 0;
      setInterval(() => {
        slides[current].style.opacity = '0';
        current = (current + 1) % slides.length;
        slides[current].style.opacity = '1';
      }, 5000);
    }
  </script>
</BaseLayout>
