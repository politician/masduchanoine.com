---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const suites = [
  {
    name: "Cannoise Suite",
    desc: "Ground floor suite opening directly onto the garden, fishpond and chestnut tree. Filled with the evening scents of orange blossom and jasmine.",
    bed: "King size bed or 2 twin beds",
    icon: "🌸",
  },
  {
    name: "Niçoise Suite",
    desc: "Bright and elegant, situated next to the fishpond and pétanque area. Enter under a lemon tree. Olive-patina furniture contrasting with lemon-yellow walls.",
    bed: "King size bed or 2 twin beds",
    icon: "🍋",
  },
  {
    name: "Saint-Pauloise Suite",
    desc: "Accessed via stone steps, offering an unobstructed view of the fortified village of Saint-Paul-de-Vence. Built in the 17th century.",
    bed: "Queen size bed",
    icon: "🏰",
  },
  {
    name: "Le Petit Mas",
    desc: "Independent family suite in the garden, ideal for 3 adults or a family. Two separate bedrooms with private access.",
    bed: "1 King bedroom + 1 Queen bedroom",
    icon: "🌿",
  },
];
---

<Layout
  title="Charming guesthouse on the French Riviera | Mas du Chanoine"
  description="Discover Mas du Chanoine, a charming B&B guesthouse in Saint-Paul de Vence on the French Riviera. 4 elegant suites, panoramic pool, homemade breakfast."
  canonical="https://masduchanoine.com/en/"
  lang="en"
  hreflang={{ fr: '/', en: '/en/' }}
>
  <Header slot="header" lang="en" currentPath="/en/" />

  <!-- Hero -->
  <section
    class="relative min-h-screen flex items-center justify-center bg-charcoal overflow-hidden"
    aria-label="Welcome to Mas du Chanoine"
  >
    <div class="absolute inset-0 bg-gradient-to-br from-charcoal via-olive-dark/80 to-charcoal/90" aria-hidden="true"></div>
    <div class="relative z-10 text-center px-4 sm:px-6 max-w-4xl mx-auto">
      <p class="font-lato text-white/70 tracking-widest uppercase text-xs sm:text-sm mb-4">
        Saint-Paul-de-Vence · Côte d'Azur · France
      </p>
      <h1 class="font-playfair text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-semibold text-white leading-tight mb-6">
        Charming guesthouse<br /><em>on the French Riviera</em>
      </h1>
      <p class="font-lato text-white/80 text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        A 17th-century Provençal house, 4 elegant suites, a heated pool and a flower-filled garden steps from the village of Saint-Paul-de-Vence.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/en/bed-breakfast/"
          class="inline-block bg-olive hover:bg-olive-dark text-white font-lato font-semibold px-8 py-4 rounded transition-colors duration-200 tracking-wide focus:outline-none focus-visible:ring-2 focus-visible:ring-white"
        >
          Our guestrooms
        </a>
        <a
          href="/en/contact-us/"
          class="inline-block border-2 border-white/70 hover:border-white text-white font-lato font-semibold px-8 py-4 rounded transition-colors duration-200 tracking-wide focus:outline-none focus-visible:ring-2 focus-visible:ring-white"
        >
          Contact us
        </a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="py-20 md:py-28 bg-cream" aria-labelledby="sec-about">
    <div class="max-w-site mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <p class="font-lato text-olive text-xs uppercase tracking-widest mb-3">Welcome</p>
          <h2 id="sec-about" class="font-playfair text-3xl md:text-4xl lg:text-5xl text-charcoal mb-6">Our Mas</h2>
          <p class="font-lato text-charcoal-light leading-relaxed mb-4">
            Nestled in the Provençal hills between Cannes and Nice, Mas du Chanoine is an authentic 17th-century manor surrounded by a beautiful garden. Pascale and Yves welcome you to a setting of exceptional character for an unforgettable stay on the Côte d'Azur.
          </p>
          <p class="font-lato text-charcoal-light leading-relaxed">
            The 4 elegantly decorated suites, heated swimming pool and family-home atmosphere make it the ideal base from which to explore the region, just minutes from the famous fortified village of Saint-Paul-de-Vence.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { icon: '🏡', title: '17th-century house', sub: 'Provençal authenticity' },
            { icon: '🛏️', title: '4 Suites', sub: 'Elegantly decorated' },
            { icon: '🏊', title: 'Heated pool', sub: '12×6m, May–October' },
            { icon: '🌺', title: 'Flower garden', sub: 'Terrace & pétanque' },
          ].map(f => (
            <div class="bg-white rounded-xl p-6 shadow-sm border border-olive/10 text-center">
              <div class="text-3xl mb-3" aria-hidden="true">{f.icon}</div>
              <p class="font-playfair font-semibold text-charcoal text-sm mb-1">{f.title}</p>
              <p class="font-lato text-charcoal-light text-xs">{f.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Suites Overview -->
  <section class="py-20 md:py-28 bg-white" aria-labelledby="sec-suites">
    <div class="max-w-site mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="font-lato text-olive text-xs uppercase tracking-widest mb-3">Accommodation</p>
        <h2 id="sec-suites" class="font-playfair text-3xl md:text-4xl lg:text-5xl text-charcoal mb-4">Our Suites</h2>
        <p class="font-lato text-charcoal-light">Each suite has its own character, blending modern comfort with Provençal charm.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
        {suites.map(suite => (
          <article class="bg-cream rounded-xl overflow-hidden shadow-sm border border-olive/10 hover:shadow-md transition-shadow duration-200 flex flex-col">
            <div class="h-32 bg-gradient-to-br from-olive/20 to-terracotta/10 flex items-center justify-center text-5xl" aria-hidden="true">
              {suite.icon}
            </div>
            <div class="p-5 flex flex-col flex-1">
              <h3 class="font-playfair text-lg font-semibold text-charcoal mb-2">{suite.name}</h3>
              <p class="font-lato text-sm text-charcoal-light leading-relaxed flex-1 mb-3">{suite.desc}</p>
              <p class="font-lato text-xs text-olive font-semibold">{suite.bed}</p>
            </div>
          </article>
        ))}
      </div>
      <div class="text-center">
        <a href="/en/bed-breakfast/" class="inline-block bg-olive hover:bg-olive-dark text-white font-lato font-semibold px-8 py-4 rounded transition-colors duration-200 tracking-wide">
          Discover all suites
        </a>
      </div>
    </div>
  </section>

  <!-- Location -->
  <section class="py-20 bg-olive text-white" aria-labelledby="sec-location">
    <div class="max-w-site mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="font-lato text-white/60 text-xs uppercase tracking-widest mb-3">Location</p>
        <h2 id="sec-location" class="font-playfair text-3xl md:text-4xl font-semibold mb-4">Ideally situated</h2>
        <p class="font-lato text-white/80 max-w-xl mx-auto">Between Cannes and Nice, a perfect base for exploring the French Riviera.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 max-w-4xl mx-auto">
        {[
          { label: 'Nice Airport', dist: '7 km' },
          { label: 'Saint-Paul village', dist: '5 min' },
          { label: 'Cagnes beaches', dist: '15 min' },
          { label: 'Antibes', dist: '15 min' },
          { label: 'Cannes', dist: '30 min' },
          { label: 'Monaco', dist: '45 min' },
        ].map(loc => (
          <div class="bg-white/10 rounded-xl p-4 text-center">
            <p class="font-playfair text-white font-semibold text-lg mb-1">{loc.dist}</p>
            <p class="font-lato text-white/70 text-xs">{loc.label}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/en/contact-us/" class="inline-block bg-white text-olive font-lato font-semibold px-8 py-4 rounded hover:bg-white/90 transition-colors">
          Book your stay
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang="en" />
</Layout>
